{
  "manifest_version": 3,
  "name": "Video Sniffer Downloader",
  "version": "0.2.2",
  "description": "Sniff webpage video URLs and send them to N_m3u8DL-RE in a local terminal window.",
  "key": "",
  "minimum_chrome_version": "116",
  "permissions": [
    "nativeMessaging",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Video Sniffer Downloader",
    "default_popup": "popup.html"
  }
}
